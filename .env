# Backend HTTP API (used by axios)
VITE_API_URL=http://localhost:4000

# Backend WebSocket / Socket.io URL (usually same host as VITE_API_URL)
VITE_WS_URL=http://localhost:4000

# Solana network — devnet or mainnet-beta
VITE_SOLANA_NETWORK=devnet

# Public Solana RPC for wallet-adapter / client-side reads. For mainnet, use a
# paid RPC (Helius, Triton) — the public endpoint is rate-limited.
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com

# Brand
VITE_PLATFORM_NAME=PumpClone
