# Production env — copy to .env.production and fill in.
#
# These values are BAKED INTO the build at `npm run build` time. Anything
# secret should NOT live here.

VITE_API_URL=https://api.yourdomain.com
VITE_WS_URL=https://api.yourdomain.com

# Solana
VITE_SOLANA_NETWORK=mainnet-beta
VITE_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_PUBLIC_KEY

# Brand
VITE_PLATFORM_NAME=PumpClone

# Optional — enables a Plausible script when set. Leave blank to disable.
VITE_ANALYTICS_DOMAIN=
